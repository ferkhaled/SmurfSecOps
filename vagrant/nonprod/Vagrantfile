# This Vagrant environment stands up the nonprod learning cluster.
# The goal is clarity over cleverness: one control plane and one worker.

Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/jammy64"

  # Sync the whole repository into the VMs so learners can access app code,
  # manifests, and docs from inside the cluster nodes.
  config.vm.synced_folder "../..", "/lab"

  nodes = [
    {
      name: "handy-ops-nonprod-cp",
      hostname: "handy-ops-nonprod-cp",
      ip: "192.168.56.11",
      memory: 2048,
      cpus: 2,
      role: "server"
    },
    {
      name: "handy-ops-nonprod-worker",
      hostname: "handy-ops-nonprod-worker",
      ip: "192.168.56.12",
      memory: 1536,
      cpus: 2,
      role: "agent"
    }
  ]

  nodes.each do |node|
    config.vm.define node[:name] do |machine|
      machine.vm.hostname = node[:hostname]
      machine.vm.network "private_network", ip: node[:ip]

      machine.vm.provider "virtualbox" do |vb|
        vb.name = node[:name]
        vb.memory = node[:memory]
        vb.cpus = node[:cpus]
      end

      machine.vm.provision "shell",
        path: "scripts/common.sh",
        args: ["nonprod"]

      if node[:role] == "server"
        machine.vm.provision "shell",
          path: "scripts/install-k3s-server.sh",
          args: ["nonprod", node[:ip]]
      else
        machine.vm.provision "shell",
          path: "scripts/install-k3s-agent.sh",
          args: ["nonprod", "192.168.56.11"]
      end
    end
  end
end
